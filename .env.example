# LLM providers — set the ones you have; select active provider in Settings or CITESEEK_LLM_PROVIDER
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434/v1

# Active LLM (anthropic | openai | gemini | deepseek | ollama)
CITESEEK_LLM_PROVIDER=anthropic
CITESEEK_LLM_MODEL=

# Scholarly APIs (both optional but recommended)
S2_API_KEY=
OPENALEX_MAILTO=you@example.com

# Storage
CITESEEK_DB_PATH=var/citeseek.db
